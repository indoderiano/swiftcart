{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user role and basic information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["buyer", "seller"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product listing created by a seller.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "category": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "sellerId"]
    },
    "Order": {
      "title": "Order",
      "description": "Purchase record for a product.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["buyerId", "sellerId", "productId", "totalPrice", "status"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "Product saved in a user's shopping cart.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" },
        "sellerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "name", "price", "quantity"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Public product listings."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Order records."
    },
    "/cart/{cartItemId}": {
      "schema": "CartItem",
      "description": "User shopping cart items."
    }
  }
}
